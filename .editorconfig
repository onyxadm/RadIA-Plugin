# EditorConfig settings for RadIA
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Delphi-specific sources (VCL/Desktop standard requires CRLF for compiler safety)
[*.{pas,dfm,dpr,dpk,rc,groupproj}]
end_of_line = crlf
indent_style = space
indent_size = 2
